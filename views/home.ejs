<!DOCTYPE html>
<html lang="en">

<head>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
    </style>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>

<body>
    <h1>URL Shortener</h1>
    <div>
        <% if (locals.id) { %>
            <p>URL Generated http://localhost:8000/shortid/<%= id %></p>
        <% } %>
        <form method="post" action="/url">
            <label for="orginal">Enter Your URL</label>
            <input type="text" name="url" id="orginal" placeholder="http://exmaple">
            <button type="submit">Generate</button>
        </form>
    </div>
    <div>
        <% if(locals.allurls) { %>
            <table>
                <thead>
                    <th>S.No</th>
                    <th>ShortID</th>
                    <th>RedirectURL</th>
                    <th>Clicks</th>
                </thead>
                <tbody>
                    <% allurls.forEach((url,index)=>{%>
                        <tr>
                            <td><%= index+1 %></td>
                            <td><%= url.shortID %></td>
                            <td><%= url.redirectURL %></td>
                            <td><%= url.visitHistory.length %></td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        <% } %>
</body>

</html>